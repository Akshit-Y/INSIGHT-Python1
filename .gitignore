cd ~/Documents/INSIGHT-Python1

cat > .gitignore << 'EOF'
# Data files - never push patient/CDM data
data/
data/cdm/
*.csv

# Output reports
output/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtual environments
venv/
env/
.env

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/
EOF