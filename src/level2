/*
===============================================================================
Level 2: Temporal Characterization 
Focus: identifying impossible or inconsistent timelines in the data.
===============================================================================
*/

-- 1. Events Before Birth
-- Flags records where clinical activity occurs before the patient's birth date.
SELECT 
    'Events Before Birth' AS check_type,
    p.person_id,
    p.birth_datetime AS reference_date,
    e.event_date AS violating_date,
    e.event_type,
    e.event_id
FROM person p
JOIN clinical_events e ON p.person_id = e.person_id
WHERE e.event_date < p.birth_datetime

UNION ALL

-- 2. Events After Death
-- Flags clinical records occurring after the recorded date of death.
SELECT 
    'Events After Death' AS check_type,
    p.person_id,
    p.death_date AS reference_date,
    e.event_date AS violating_date,
    e.event_type,
    e.event_id
FROM person p
JOIN clinical_events e ON p.person_id = e.person_id
WHERE p.death_date IS NOT NULL 
  AND e.event_date > p.death_date

UNION ALL

-- 3. Outside Observation Periods
-- Catching events recorded before a patient first enters the data source or after they exit.
SELECT 
    'Outside Observation Period' AS check_type,
    e.person_id,
    o.observation_period_start_date AS reference_date,
    e.event_date AS violating_date,
    e.event_type,
    e.event_id
FROM clinical_events e
JOIN observation_period o ON e.person_id = o.person_id
WHERE e.event_date < o.observation_period_start_date 
   OR e.event_date > o.observation_period_end_date

UNION ALL

-- 4. Cross-table Temporal Consistency (Visit Logic)
-- Verifying that discharge doesn't happen before admission.
SELECT 
    'Invalid Visit Duration' AS check_type,
    person_id,
    visit_start_date AS reference_date,
    visit_end_date AS violating_date,
    'Visit Record' AS event_type,
    visit_occurrence_id AS event_id
FROM visit_occurrence
WHERE visit_end_date < visit_start_date

UNION ALL

-- 5. Cross-table Temporal Consistency (Prescriptions)
-- Ensuring prescriptions don't occur before the patient was even enrolled/enrolled.
SELECT 
    'Prescription Before Enrollment' AS check_type,
    d.person_id,
    o.observation_period_start_date AS reference_date,
    d.drug_exposure_start_date AS violating_date,
    'Drug Exposure' AS event_type,
    d.drug_exposure_id AS event_id
FROM drug_exposure d
JOIN observation_period o ON d.person_id = o.person_id
WHERE d.drug_exposure_start_date < o.observation_period_start_date;